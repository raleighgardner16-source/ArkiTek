# =============================================================================
# ArkiTek Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Variables without defaults are REQUIRED in production.
# Variables with defaults shown are optional.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net
DB_NAME=Arkitek
ADMIN_DB_NAME=Arkitek

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# REQUIRED in production — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3001
APP_URL=https://your-domain.com
# Comma-separated list of allowed CORS origins (leave empty to allow all)
ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# LLM Provider API Keys (at least one required for the app to work)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
META_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=

# -----------------------------------------------------------------------------
# Web Search
# -----------------------------------------------------------------------------
SERPER_API_KEY=

# -----------------------------------------------------------------------------
# Stripe (required for payments)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Email (required for email verification, password reset)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
FROM_EMAIL=noreply@arkitek.app

# -----------------------------------------------------------------------------
# Logging (optional — defaults to "info" in production, "debug" in development)
# -----------------------------------------------------------------------------
# Pino log levels: fatal, error, warn, info, debug, trace, silent
LOG_LEVEL=

# -----------------------------------------------------------------------------
# Error Tracking (optional — leave empty to disable)
# -----------------------------------------------------------------------------
# Get your DSN from https://sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=
# Frontend Sentry DSN (exposed to browser — must use VITE_ prefix)
VITE_SENTRY_DSN=
