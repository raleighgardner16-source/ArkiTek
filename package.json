{
  "name": "arktek",
  "version": "1.0.0",
  "type": "module",
  "description": "Multi-LLM Comparison Platform with VR-like Interface",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx server.ts",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev\"",
    "build": "vite build",
    "build:server": "npm run build && tsx server.ts",
    "start": "tsx server.ts",
    "preview": "vite preview",
    "db:migrate": "tsx database/migrate.ts",
    "db:migrate:dry": "tsx database/migrate.ts --dry-run",
    "db:verify": "tsx database/migrate.ts --verify",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.app.json",
    "typecheck:server": "tsc --noEmit",
    "typecheck:client": "tsc --noEmit -p tsconfig.app.json",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"server/**/*.ts\" \"database/**/*.ts\" \"utils/**/*.ts\" \"scripts/**/*.ts\" \"tests/**/*.ts\" \"*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"server/**/*.ts\" \"database/**/*.ts\" \"utils/**/*.ts\" \"scripts/**/*.ts\" \"tests/**/*.ts\" \"*.ts\"",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fingerprintjs/fingerprintjs": "^5.0.1",
    "@sentry/node": "^10.40.0",
    "@sentry/react": "^10.40.0",
    "@stripe/react-stripe-js": "^5.6.0",
    "@stripe/stripe-js": "^8.7.0",
    "axios": "^1.6.2",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "disposable-email-domains": "^1.0.62",
    "dotenv": "^16.3.1",
    "envalid": "^8.1.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "framer-motion": "^10.16.16",
    "jsonwebtoken": "^9.0.3",
    "katex": "^0.16.28",
    "lucide-react": "^0.294.0",
    "mongodb": "^6.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "resend": "^6.9.2",
    "stripe": "^14.10.0",
    "tiktoken": "^1.0.22",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.2",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.8",
    "vitest": "^4.0.18"
  }
}
